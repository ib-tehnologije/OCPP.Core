@model OCPP.Core.Management.Models.PublicStartViewModel
@{
    Layout = "_PublicPortalLayout";
    ViewData["Title"] = "Start charging";
    ViewData["PublicPageTitle"] = $"Start charging - {Model.ChargePointName ?? Model.ChargePointId}";
    ViewData["PublicPageDescription"] = "Start charging, review pricing, and continue to secure payment.";
    ViewData["PublicNav"] = "map";
    var chargePointLabel = string.IsNullOrWhiteSpace(Model.ChargePointName)
        ? Model.ChargePointId
        : Model.ChargePointName;
    var connectorLabel = string.IsNullOrWhiteSpace(Model.ConnectorName)
        ? (!string.IsNullOrWhiteSpace(Model.PublicConnectorShortCode)
            ? Model.PublicConnectorShortCode
            : $"Connector {Model.ConnectorId}")
        : Model.ConnectorName;
    var selectedConnectorCode = string.IsNullOrWhiteSpace(Model.PublicConnectorCode)
        ? connectorLabel
        : Model.PublicConnectorCode;
    var allowLocalConnectorSwitching = Model.ShowConnectorSelector && !Model.HasRecoveryOptions && !Model.HasError;
    var badgeClass = "waiting";
    if (string.Equals(Model.LastStatus, "Available", StringComparison.OrdinalIgnoreCase)) badgeClass = "available";
    if (string.Equals(Model.LastStatus, "Offline", StringComparison.OrdinalIgnoreCase)) badgeClass = "error";
    if (string.Equals(Model.LastStatus, "Occupied", StringComparison.OrdinalIgnoreCase))
    {
        badgeClass = "charging";
    }
    var isFree = Model.FreeChargingEnabled || (Model.PricePerKwh <= 0 && Model.ConnectorUsageFeePerMinute <= 0 && Model.UserSessionFee <= 0);
    var mapUrl = Url.Action("Index", "Public");
    var statusLabel = string.IsNullOrWhiteSpace(Model.LastStatus) ? "Offline" : Model.LastStatus;
    if (isFree && string.Equals(statusLabel, "Available", StringComparison.OrdinalIgnoreCase))
    {
        statusLabel = "Free charging";
    }

    string ConnectorBadgeClass(string status)
    {
        if (string.Equals(status, "Available", StringComparison.OrdinalIgnoreCase))
        {
            return "available";
        }

        if (string.Equals(status, "Offline", StringComparison.OrdinalIgnoreCase))
        {
            return "error";
        }

        if (string.Equals(status, "Occupied", StringComparison.OrdinalIgnoreCase))
        {
            return "charging";
        }

        return "waiting";
    }
}

    <nav class="public-session-nav" aria-label="Charging session states">
        <button type="button" class="active" disabled>① Start</button>
        <button type="button" disabled>② Wait</button>
        <button type="button" disabled>③ Charge</button>
        <button type="button" disabled>④ Done</button>
        <button type="button" disabled>⑤ Error</button>
    </nav>

    <div class="page-wrap">
        <div class="card">
            <div class="status-header">
                <div class="status-badge @badgeClass">
                    <span class="dot"></span>
                    <span id="connector-status-text">@statusLabel</span>
                </div>
                <h1 class="charger-title">@chargePointLabel</h1>
                @if (!string.IsNullOrWhiteSpace(Model.LocationDescription))
                {
                    <p class="charger-sub charger-sub--location" id="charger-location">@Model.LocationDescription</p>
                }
                <p class="charger-sub" id="charger-sub">@connectorLabel</p>
                <div class="public-code-row">
                    @if (!string.IsNullOrWhiteSpace(Model.PublicDisplayCode))
                    {
                        <span class="public-code-pill" id="charge-point-public-code">@Model.PublicDisplayCode</span>
                    }
                    <span class="public-code-pill public-code-pill--connector" id="connector-public-code">@selectedConnectorCode</span>
                </div>
            </div>

            @if (Model.ShowConnectorSelector)
            {
                <div class="divider"></div>
                <div class="info-section connector-selector-section">
                            <div class="info-section-title" data-i18n="start.chooseConnector">Choose connector</div>
                    <div class="connector-selector" data-local-switching="@(allowLocalConnectorSwitching ? "true" : "false")">
                        @foreach (var connector in Model.Connectors)
                        {
                            var connectorUrl = Url.RouteUrl("public-start-path", new { cp = Model.ChargePointId, conn = connector.ConnectorId })
                                ?? Url.Action("Start", "Public", new { cp = Model.ChargePointId, conn = connector.ConnectorId });
                            var connectorBadgeClass = ConnectorBadgeClass(connector.LastStatus);
                            var connectorPrimaryLabel = connector.Label;
                            var connectorSecondaryLabel = !string.IsNullOrWhiteSpace(connector.PublicConnectorShortCode) &&
                                !string.Equals(connector.PublicConnectorShortCode, connectorPrimaryLabel, StringComparison.OrdinalIgnoreCase)
                                ? connector.PublicConnectorShortCode
                                : null;
                            var connectorStatusLabel = string.IsNullOrWhiteSpace(connector.LastStatus) ? "Offline" : connector.LastStatus;
                            if (isFree && string.Equals(connectorStatusLabel, "Available", StringComparison.OrdinalIgnoreCase))
                            {
                                connectorStatusLabel = "Free charging";
                            }
                            <a class="connector-option @(connector.IsSelected ? "selected" : "")"
                               href="@connectorUrl"
                               data-connector-id="@connector.ConnectorId"
                               data-connector-label="@connector.Label"
                               data-connector-name="@connector.DisplayName"
                               data-last-status="@connectorStatusLabel"
                               data-badge-class="@connectorBadgeClass"
                               data-availability-message="@connector.AvailabilityMessage"
                               data-public-code="@connector.PublicConnectorCode"
                               data-public-short-code="@connector.PublicConnectorShortCode"
                               aria-current="@(connector.IsSelected ? "page" : null)">
                                <div class="connector-option-top">
                                    <div>
                                        <div class="connector-option-label">@connectorPrimaryLabel</div>
                                        @if (!string.IsNullOrWhiteSpace(connectorSecondaryLabel))
                                        {
                                            <div class="connector-option-sub">@connectorSecondaryLabel</div>
                                        }
                                    </div>
                                    <div class="status-badge @connectorBadgeClass">
                                        <span class="dot"></span>
                                        <span>@connectorStatusLabel</span>
                                    </div>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(connector.PublicConnectorCode))
                                {
                                    <div class="connector-option-code">@connector.PublicConnectorCode</div>
                                }
                                <div class="connector-option-meta">
                                    <span data-default-text="Tap to switch" data-selected-text="Selected connector">
                                        @(connector.IsSelected ? "Selected connector" : "Tap to switch")
                                    </span>
                                </div>
                            </a>
                        }
                    </div>
                </div>
            }

            <div class="divider"></div>

            <div class="info-section">
                <div class="info-section-title" data-i18n="start.prices">Prices & fees</div>
                <div class="info-row">
                    <div class="tile featured">
                        <div class="label">Energy</div>
                        <div class="value">
                            @if (Model.PricePerKwh > 0)
                            {
                                <span>@Model.PricePerKwh.ToString("0.##")</span><span class="unit">@Model.CurrencySymbol/kWh</span>
                            }
                            else
                            {
                                <span class="highlight">Free</span><span class="unit">energy</span>
                            }
                        </div>
                    </div>
                    <div class="tile">
                        <div class="label">Session fee</div>
                        <div class="value">
                            @if (Model.UserSessionFee > 0)
                            {
                                <span>@Model.UserSessionFee.ToString("0.##")</span><span class="unit">@Model.CurrencySymbol</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="info-row">
                    <div class="tile full" style="border-color: var(--warning-border); background: var(--warning-bg);">
                        <div class="label" style="color: var(--warning);">⏱ Idle fee</div>
                        <div class="value">
                            @if (Model.ConnectorUsageFeePerMinute > 0)
                            {
                                <span>@Model.ConnectorUsageFeePerMinute.ToString("0.##")</span><span class="unit">@Model.CurrencySymbol/min</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                        @if (Model.ConnectorUsageFeePerMinute > 0)
                        {
                            <div class="sub" style="color:#fde68a;">
                                @(Model.UsageFeeAfterChargingEnds ? "Charged after charging ends" : "Charged from session start") · grace @Model.StartUsageFeeAfterMinutes min · max @Model.MaxUsageFeeBillableMinutes min
                            </div>
                        }
                    </div>
                </div>

                <div class="info-row">
                    <div class="tile">
                        <div class="label">Max. energy</div>
                        <div class="value">
                            @if (Model.MaxSessionKwh > 0)
                            {
                                <span>@Model.MaxSessionKwh.ToString("0.#")</span><span class="unit">kWh</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>
                    <div class="tile">
                        <div class="label">Pre-authorization (est.)</div>
                        <div class="value">
                            @if (Model.EstimatedMaxHold > 0)
                            {
                                <span>@Model.EstimatedMaxHold.ToString("0.##")</span><span class="unit">@Model.CurrencySymbol</span>
                            }
                            else
                            {
                                <span>-</span>
                            }
                        </div>
                    </div>
                </div>

                <div class="info-row">
                    <div class="tile full" style="background: transparent; border-style: dashed;">
                        <div class="sub" style="margin:0;">💡 Final amount = energy + session fee + idle fee (if any). Difference from pre-auth is refunded automatically.</div>
                    </div>
                </div>
            </div>

            <div class="divider"></div>

            @if (!Model.HasRecoveryOptions)
            {
                <div class="alert-box warning alert-box--section" id="availability-message" @(!Model.HasAvailabilityMessage ? "hidden" : null)>
                    <span class="alert-icon">⏳</span>
                    <span data-availability-text>@Model.AvailabilityMessage</span>
                </div>
            }

            @if (Model.HasRecoveryOptions)
            {
                <div class="form-section">
                    <div class="alert-box warning alert-box--stack">
                        <span class="alert-icon">⏳</span>
                        <span>@Model.RecoveryMessage</span>
                    </div>

                    <div class="field-help field-help--spaced">Reservation <span class="mono">@Model.RecoveryReservationId</span> · status @Model.RecoveryReservationStatus</div>

                    @if (Model.CanResumeRecovery)
                    {
                        <a class="btn-primary" href="@Model.RecoveryCheckoutUrl">
                            <span>Resume payment</span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </a>
                    }

                    <form method="post" asp-action="CancelRecovery" class="stack-gap-sm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="chargePointId" value="@Model.ChargePointId" />
                        <input type="hidden" name="connectorId" value="@Model.ConnectorId" />
                        <input type="hidden" name="reservationId" value="@Model.RecoveryReservationId" />
                        <button type="submit" class="btn-secondary">Cancel previous attempt</button>
                    </form>

                    <a class="btn-secondary stack-gap-sm" href="@mapUrl">Back to map</a>
                </div>
            }
            else
            {
                <div class="form-section">
                    <form method="post" asp-action="Start">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="ChargePointId" value="@Model.ChargePointId" />
                        <input type="hidden" name="ConnectorId" value="@Model.ConnectorId" />

                        <label class="r1-checkbox">
                            <input type="checkbox" id="wantsR1" name="RequestR1Invoice" value="true" @(Model.RequestR1Invoice ? "checked" : "")>
                            <div class="r1-label">
                                <strong data-i18n="start.companyInvoice">Company invoice</strong>
                                <span class="r1-hint">If you need an R1 invoice, enter your company info below or add it later from the session status page.</span>
                            </div>
                        </label>

                        <div id="r1Fields" style="display:@(Model.RequestR1Invoice ? "block" : "none"); margin-bottom: 14px;">
                        <label for="buyerCompanyName" class="field-label" data-i18n="start.companyName">Company name (optional)</label>
                        <input type="text" class="field-input" id="buyerCompanyName" name="BuyerCompanyName" value="@Model.BuyerCompanyName" placeholder="Company / organization name" data-i18n-placeholder="start.companyNamePlaceholder" autocomplete="organization" />

                        <label for="buyerOib" class="field-label field-label--spaced" data-i18n="start.oib">OIB (required for R1)</label>
                        <input type="text" class="field-input" id="buyerOib" name="BuyerOib" value="@Model.BuyerOib" placeholder="11 digits" data-i18n-placeholder="start.oibPlaceholder" inputmode="numeric" autocomplete="off" pattern="[0-9]{11}" maxlength="11" />
                        <div class="field-help">We will include this information in Stripe metadata so you can issue an R1 invoice.</div>
                    </div>

                        <button type="submit" class="btn-primary">
                            <span data-i18n="@(isFree ? "start.startFree" : "start.startCharging")">@(isFree ? "Start free session" : "Start charging")</span>
                            <span class="arrow" aria-hidden="true">→</span>
                        </button>

                        <a class="btn-secondary" href="@mapUrl" data-i18n="start.backToMap">Back to map</a>
                    </form>
                </div>
            }

            <script>
                (function () {
                    const wantsR1 = document.getElementById('wantsR1');
                    const fields = document.getElementById('r1Fields');
                    if (!wantsR1 || !fields) return;
                    const sync = () => {
                        const enabled = wantsR1.checked;
                        fields.style.display = enabled ? 'block' : 'none';
                        const inputs = fields.querySelectorAll('input, select, textarea');
                        inputs.forEach(i => i.disabled = !enabled);
                    };
                    wantsR1.addEventListener('change', sync);
                    sync();
                })();

                (function () {
                    const selector = document.querySelector('.connector-selector[data-local-switching="true"]');
                    const connectorInput = document.querySelector('input[name="ConnectorId"]');
                    const badge = document.querySelector('.status-header .status-badge');
                    const badgeText = document.getElementById('connector-status-text');
                    const connectorName = document.getElementById('charger-sub');
                    const connectorCode = document.getElementById('connector-public-code');
                    const availabilityBox = document.getElementById('availability-message');
                    const availabilityText = availabilityBox ? availabilityBox.querySelector('[data-availability-text]') : null;

                    if (!selector || !connectorInput || !badge || !badgeText || !connectorName || !connectorCode || !window.history || typeof window.history.replaceState !== 'function') {
                        return;
                    }

                    const options = Array.from(selector.querySelectorAll('.connector-option'));
                    if (options.length === 0) {
                        return;
                    }

                    const syncMeta = (activeOption) => {
                        options.forEach((option) => {
                            option.classList.toggle('selected', option === activeOption);
                            if (option === activeOption) {
                                option.setAttribute('aria-current', 'page');
                            } else {
                                option.removeAttribute('aria-current');
                            }

                            const meta = option.querySelector('.connector-option-meta span');
                            if (meta) {
                                meta.textContent = option === activeOption
                                    ? (meta.dataset.selectedText || meta.textContent)
                                    : (meta.dataset.defaultText || meta.textContent);
                            }
                        });
                    };

                    const updateAvailability = (message) => {
                        if (!availabilityBox || !availabilityText) {
                            return;
                        }

                        if (message) {
                            availabilityBox.hidden = false;
                            availabilityText.textContent = message;
                        } else {
                            availabilityBox.hidden = true;
                            availabilityText.textContent = '';
                        }
                    };

                    const applyConnector = (option) => {
                        if (!option) {
                            return;
                        }

                        const connectorId = option.dataset.connectorId || '';
                        const statusText = option.dataset.lastStatus || 'Offline';
                        const badgeClass = option.dataset.badgeClass || 'waiting';
                        const displayLabel = option.dataset.connectorLabel || option.dataset.connectorName || `Connector ${connectorId}`;
                        const publicCode = option.dataset.publicCode || displayLabel;
                        const availabilityMessage = option.dataset.availabilityMessage || '';

                        connectorInput.value = connectorId;
                        badge.className = `status-badge ${badgeClass}`;
                        badgeText.textContent = statusText;
                        connectorName.textContent = displayLabel;
                        connectorCode.textContent = publicCode;
                        updateAvailability(availabilityMessage);
                        syncMeta(option);

                        const nextUrl = option.getAttribute('href');
                        if (nextUrl) {
                            window.history.replaceState({ connectorId }, '', nextUrl);
                        }
                    };

                    options.forEach((option) => {
                        option.addEventListener('click', (event) => {
                            if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
                                return;
                            }

                            event.preventDefault();
                            applyConnector(option);
                        });
                    });
                })();
            </script>

            @if (Model.HasError)
            {
                <div class="alert-box danger alert-box--flush">
                    <span class="alert-icon">⚠️</span>
                    <span>@Model.ErrorMessage</span>
                </div>
            }
            else if (Model.HasRecoveryOptions)
            {
                <div class="alert-box warning alert-box--flush">
                    <span class="alert-icon">⏳</span>
                    <span data-i18n="start.finishPreviousCheckout">Finish or cancel the previous checkout before starting a new session on this connector.</span>
                </div>
            }
            else
            {
                <div class="alert-box info alert-box--flush">
                    <span class="alert-icon">🔒</span>
                    <span data-i18n="@(Model.FreeChargingEnabled ? "start.freeInfo" : "start.secureInfo")">@(Model.FreeChargingEnabled ? "Free charging enabled. No payment will be charged." : "Secure payment via Stripe. Only the actual cost is charged.")</span>
                </div>
            }
        </div>
    </div>
