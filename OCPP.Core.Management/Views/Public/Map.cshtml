@model OCPP.Core.Management.Models.PublicMapViewModel
@{
    Layout = "_PublicPortalLayout";
    ViewData["Title"] = "Charging map";
    ViewData["PublicPageTitle"] = "Charging map";
    ViewData["PublicPageDescription"] = "Find the nearest charger, scan a QR code, and start charging.";
    ViewData["PublicNav"] = "map";
    var hasCoords = Model.ChargePoints?.Any(cp => cp.Latitude.HasValue && cp.Longitude.HasValue) == true;
}
@section Head {
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
}
    <div class="page-wrap page-wrap--top">
        <div class="map-container">
            <div class="card card--wide">
                <div class="map-header">
                    <h2 data-i18n="map.title">Charging map</h2>
                    <div class="charger-count"><span>@Model.ChargePoints.Count</span> <span data-i18n="map.stations">station(s)</span></div>
                </div>

                <div class="map-canvas-wrap">
                    @if (hasCoords)
                    {
                        <div class="map-stage">
                            <button id="gpsBtn" type="button" title="Center on your location" data-i18n-title="map.centerOnLocation" class="map-control-btn map-control-btn--gps">
                                <span data-i18n="map.gps">GPS</span>
                            </button>
                            <button id="mapExpandBtn" type="button" title="Expand map" data-i18n-title="map.expandTitle" class="map-control-btn map-control-btn--expand">
                                <span data-i18n="map.expand">Expand</span>
                            </button>
                            <div id="map"></div>
                        </div>
                    }
                    else
                    {
                        <div class="alert-box warning map-alert-box">
                            <span class="alert-icon">🗺️</span>
                            <span data-i18n="map.noCoords">No map data available (missing coordinates).</span>
                        </div>
                    }
                </div>

                <div class="map-legend">
                    <div class="legend-item"><div class="legend-dot online"></div><span data-i18n="map.available">Available</span></div>
                    <div class="legend-item"><div class="legend-dot busy"></div><span data-i18n="map.busy">Busy</span></div>
                    <div class="legend-item"><div class="legend-dot offline"></div><span data-i18n="map.offline">Offline</span></div>
                </div>

                <div class="map-search-wrap">
                    <div class="map-search">
                        <span class="map-search-icon">🔍</span>
                        <input type="text" id="mapSearch" placeholder="Search by name, location, or charge point id..." data-i18n-placeholder="map.search" autocomplete="off" />
                        <button type="button" class="map-search-clear" id="mapSearchClear" aria-label="Clear search" data-i18n-aria-label="map.clearSearch">&times;</button>
                    </div>
                </div>

                <div class="divider"></div>

                <div class="map-section-header">
                    <div class="info-section-title" data-i18n="map.stationsOnMap">Stations on map</div>
                </div>

                <div class="charger-list" id="charger-list">
                    @if (Model.ChargePoints.Count == 0)
                    {
                        <div class="tile full">
                            <div class="label" data-i18n="map.noStations">No stations configured yet.</div>
                        </div>
                    }
                    else
                    {
                        foreach (var cp in Model.ChargePoints)
                        {
                            var statusClass = "busy";
                            var publicStationCode = string.IsNullOrWhiteSpace(cp.PublicDisplayCode) ? cp.ChargePointId : cp.PublicDisplayCode;
                            var availabilitySummary = cp.ConnectorCount > 0
                                ? $"{cp.AvailableConnectorCount}/{cp.ConnectorCount}"
                                : "0/0";
                            if (string.Equals(cp.Status, "Available", StringComparison.InvariantCultureIgnoreCase))
                            {
                                statusClass = "online";
                            }
                            else if (string.Equals(cp.Status, "Offline", StringComparison.InvariantCultureIgnoreCase))
                            {
                                statusClass = "offline";
                            }

                            var startUrl = cp.HasMultipleConnectors
                                ? Url.RouteUrl("public-start-charge-point", new { cp = cp.ChargePointId })
                                    ?? Url.Action("Start", "Public", new { cp = cp.ChargePointId })
                                : Url.RouteUrl("public-start-path", new { cp = cp.ChargePointId, conn = 1 })
                                    ?? Url.Action("Start", "Public", new { cp = cp.ChargePointId, conn = 1 });
                            var startLabel = cp.HasMultipleConnectors ? "Choose connector" : "Start session";
                            var searchText = $"{cp.Name} {cp.LocationDescription} {publicStationCode}";
                            <div class="charger-card cp-card" data-search="@searchText" data-cp-id="@cp.ChargePointId">
                                <div class="cc-top">
                                    <div class="cc-name">@cp.Name</div>
                                    <div class="cc-status @statusClass" data-i18n-status="@cp.Status">@cp.Status</div>
                                </div>
                                <div class="cc-code">@publicStationCode</div>
                                <div class="cc-detail">@cp.LocationDescription</div>
                                <div class="cc-detail">@cp.ConnectorCount <span data-i18n="map.connectors">connector(s)</span></div>
                                @if (string.Equals(cp.Status, "Offline", StringComparison.InvariantCultureIgnoreCase))
                                {
                                    <div class="cc-detail"><span data-i18n="map.offline">Offline</span></div>
                                }
                                else
                                {
                                    <div class="cc-detail">@availabilitySummary <span data-i18n="map.available">Available</span></div>
                                }
                                <div class="cc-detail">
                                    @if (cp.PricePerKwh > 0)
                                    {
                                        <span class="cc-power">@cp.PricePerKwh.ToString("0.##") @Model.CurrencySymbol / kWh</span>
                                    }
                                    else
                                    {
                                        <span class="cc-power" data-i18n="map.freeEnergy">Free energy</span>
                                    }
                                    @if (cp.UserSessionFee > 0)
                                    {
                                        <span> · <span data-i18n="map.sessionFee">Session fee</span> @cp.UserSessionFee.ToString("0.##") @Model.CurrencySymbol</span>
                                    }
                                </div>
                                @if (cp.ConnectorUsageFeePerMinute > 0)
                                {
                                    <div class="cc-detail">
                                        <span data-i18n="map.idleFee">Idle fee</span> @cp.ConnectorUsageFeePerMinute.ToString("0.##") @Model.CurrencySymbol/min (<span data-i18n="map.grace">grace</span> @cp.StartUsageFeeAfterMinutes <span data-i18n="map.minutes">min</span>)
                                        @if (Model.HasIdleFeeExcludedWindow)
                                        {
                                            <span> · <span data-i18n="start.idleFreeWindow">free</span> @Model.IdleFeeExcludedWindow</span>
                                        }
                                    </div>
                                }
                                <div class="cc-actions">
                                    <a href="@startUrl" onclick="event.stopPropagation();" data-i18n="@(cp.HasMultipleConnectors ? "map.chooseConnector" : "map.startSession")">@startLabel</a>
                                </div>
                            </div>
                        }
                    }
                    @if (Model.ChargePoints.Count > 0)
                    {
                        <div class="tile full" id="charger-list-empty" hidden>
                            <div class="label" data-i18n="map.noVisibleStations">No stations match the current map view.</div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>

    @if (hasCoords)
    {
        <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
        <script>
            const points = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.ChargePoints ?? new List<PublicMapChargePoint>()));
            if (typeof L === 'undefined' || typeof L.map !== 'function') {
                console.error('Public map: Leaflet library failed to load.');
            } else {
            const map = L.map('map');
            const listEl = document.getElementById('charger-list');
            const searchInput = document.getElementById('mapSearch');
            const clearSearch = document.getElementById('mapSearchClear');
            const gpsBtn = document.getElementById('gpsBtn');
            const mapExpandBtn = document.getElementById('mapExpandBtn');
            const mapExpandLabel = mapExpandBtn ? mapExpandBtn.querySelector('[data-i18n]') : null;
            const chargerCountValue = document.querySelector('.charger-count span:first-child');
            const emptyStateEl = document.getElementById('charger-list-empty');
            const publicStyles = getComputedStyle(document.documentElement);
            const publicThemeColor = (name, fallback) => publicStyles.getPropertyValue(name).trim() || fallback;
            const markerColors = {
                available: publicThemeColor('--public-success', '#047857'),
                offline: publicThemeColor('--public-danger', '#b91c1c'),
                busy: publicThemeColor('--public-accent-2', '#2563eb')
            };
            const selectedMarkerColor = publicThemeColor('--public-warning', '#fbbf24');
            const mapBoundsPaddingPx = 16;
            const markerLookup = {};
            let userMarker = null;
            let activeQuery = '';
            let mapViewportReady = false;
            let selectedChargePointId = null;
            const mapFallbackTranslations = {
                hr: {
                    "map.availableCount": "{available}/{total} dostupno",
                    "map.noUsableCoordinates": "Nisu pronađene upotrebljive koordinate za oznake na karti.",
                    "map.unnamedStation": "(Neimenovana postaja)",
                    "map.expand": "Proširi",
                    "map.shrink": "Smanji",
                    "map.offline": "Nedostupno"
                },
                en: {
                    "map.availableCount": "{available}/{total} available",
                    "map.noUsableCoordinates": "No usable coordinates were found for map markers.",
                    "map.unnamedStation": "(Unnamed station)",
                    "map.expand": "Expand",
                    "map.shrink": "Shrink",
                    "map.offline": "Offline"
                },
                sl: {
                    "map.availableCount": "{available}/{total} na voljo",
                    "map.noUsableCoordinates": "Za oznake na zemljevidu ni bilo najdenih uporabnih koordinat.",
                    "map.unnamedStation": "(Neimenovana postaja)",
                    "map.expand": "Razširi",
                    "map.shrink": "Zmanjšaj",
                    "map.offline": "Nedosegljivo"
                },
                it: {
                    "map.availableCount": "{available}/{total} disponibili",
                    "map.noUsableCoordinates": "Non sono state trovate coordinate utilizzabili per i marker della mappa.",
                    "map.unnamedStation": "(Stazione senza nome)",
                    "map.expand": "Espandi",
                    "map.shrink": "Riduci",
                    "map.offline": "Offline"
                },
                de: {
                    "map.availableCount": "{available}/{total} verfügbar",
                    "map.noUsableCoordinates": "Es wurden keine nutzbaren Koordinaten für Kartenmarker gefunden.",
                    "map.unnamedStation": "(Unbenannte Station)",
                    "map.expand": "Vergrößern",
                    "map.shrink": "Verkleinern",
                    "map.offline": "Offline"
                },
                fr: {
                    "map.availableCount": "{available}/{total} disponibles",
                    "map.noUsableCoordinates": "Aucune coordonnée utilisable n'a été trouvée pour les marqueurs de carte.",
                    "map.unnamedStation": "(Station sans nom)",
                    "map.expand": "Agrandir",
                    "map.shrink": "Réduire",
                    "map.offline": "Hors ligne"
                }
            };
            const i18n = () => window.publicPortalI18n;
            const currentLang = () => {
                const activeI18n = i18n();
                if (activeI18n && typeof activeI18n.currentLanguage === 'function') {
                    return activeI18n.currentLanguage();
                }

                const params = new URLSearchParams(window.location.search);
                const fromQuery = params.get('lang');
                if (mapFallbackTranslations[fromQuery]) {
                    return fromQuery;
                }

                const stored = localStorage.getItem('publicPortalLang');
                return mapFallbackTranslations[stored] ? stored : 'en';
            };
            const t = (key) => {
                const lang = currentLang();
                return i18n()?.textFor?.(lang, key)
                    || mapFallbackTranslations[lang]?.[key]
                    || mapFallbackTranslations.en[key]
                    || key;
            };
            const formatText = (key, values) => {
                const lang = currentLang();
                const formatter = i18n()?.formatTextFor;
                let text = typeof formatter === 'function'
                    ? formatter(lang, key, values)
                    : t(key);
                Object.entries(values || {}).forEach(([name, value]) => {
                    text = text.replaceAll(`{${name}}`, value);
                });
                return text;
            };
            const statusText = (value) => {
                const lang = currentLang();
                const translated = i18n()?.statusTextFor?.(lang, value);
                if (translated) {
                    return translated;
                }

                const normalized = String(value || '').trim().toLowerCase();
                if (normalized === 'offline') {
                    return t('map.offline');
                }

                return value;
            };

            const pick = (obj, primary, secondary) => {
                if (obj[primary] !== undefined && obj[primary] !== null) return obj[primary];
                if (obj[secondary] !== undefined && obj[secondary] !== null) return obj[secondary];
                return '';
            };

            const asNumber = (value) => {
                if (value === null || value === undefined) return null;
                if (typeof value === 'string') {
                    const trimmed = value.trim();
                    if (trimmed.length === 0) return null;
                    value = trimmed;
                }
                const num = Number(value);
                return Number.isFinite(num) ? num : null;
            };

            const hasLocation = points.filter(p => {
                const lat = asNumber(pick(p, 'Latitude', 'latitude'));
                const lng = asNumber(pick(p, 'Longitude', 'longitude'));
                return lat !== null && lng !== null;
            });

            if (hasLocation.length > 0) {
                const bounds = L.latLngBounds(hasLocation.map(p => [asNumber(pick(p, 'Latitude', 'latitude')), asNumber(pick(p, 'Longitude', 'longitude'))]));
                map.fitBounds(bounds.pad(0.2));
            } else {
                map.setView([0, 0], 2);
                const mapRoot = document.getElementById('map');
                if (mapRoot) {
                    mapRoot.insertAdjacentHTML('beforeend', `<div class="public-empty-state">${escapeHtml(t('map.noUsableCoordinates'))}</div>`);
                }
            }

            L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            hasLocation.forEach(p => {
                const chargePointId = pick(p, 'ChargePointId', 'chargePointId');
                const name = (pick(p, 'Name', 'name') || '').trim() || t('map.unnamedStation');
                const status = (pick(p, 'Status', 'status') || '').toLowerCase();
                const publicDisplayCode = (pick(p, 'PublicDisplayCode', 'publicDisplayCode') || '').trim();
                const publicStationCode = publicDisplayCode || chargePointId;
                const connectorCount = Number(pick(p, 'ConnectorCount', 'connectorCount')) || 0;
                const availableConnectorCount = Number(pick(p, 'AvailableConnectorCount', 'availableConnectorCount')) || 0;
                const availabilitySummary = status === 'offline'
                    ? statusText('Offline')
                    : formatText('map.availableCount', { available: availableConnectorCount, total: connectorCount });
                let color = markerColors.available;
                if (status.includes('offline')) {
                    color = markerColors.offline;
                } else if (!status.includes('avail')) {
                    color = markerColors.busy;
                }

                const lat = asNumber(pick(p, 'Latitude', 'latitude'));
                const lng = asNumber(pick(p, 'Longitude', 'longitude'));
                const markerStyle = {
                    radius: 8,
                    color: color,
                    fillColor: color,
                    fillOpacity: 0.85,
                    weight: 1
                };
                const marker = L.circleMarker([lat, lng], markerStyle).addTo(map);
                marker._publicDefaultStyle = markerStyle;

                const addr = (pick(p, 'LocationDescription', 'locationDescription') || '').trim();
                const tooltipHtml = [
                    `<div class="popup-name">${escapeHtml(name)}</div>`,
                    publicStationCode ? `<div class="popup-code">${escapeHtml(publicStationCode)}</div>` : '',
                    addr ? `<div class="popup-addr">${escapeHtml(addr)}</div>` : '',
                    `<div class="popup-status">${escapeHtml(availabilitySummary)}</div>`
                ].filter(Boolean).join('');
                marker.bindTooltip(tooltipHtml, {
                    direction: 'top',
                    offset: [0, -6],
                    opacity: 0.96,
                    sticky: true
                });
                markerLookup[chargePointId] = marker;

                marker.on('click', ev => {
                    if (ev && ev.originalEvent) {
                        L.DomEvent.stopPropagation(ev.originalEvent);
                    }

                    const card = findCardByCpId(chargePointId);
                    if (card) {
                        marker.openTooltip();
                        scrollToChargerList(card, 'map');
                    }
                });
            });

            function escapeHtml(value) {
                return String(value || '').replace(/[&<>"']/g, match => ({
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    '"': '&quot;',
                    "'": '&#39;'
                }[match]));
            }

            function getCurrentBounds() {
                if (!mapViewportReady || !map || typeof map.getBounds !== 'function') {
                    return null;
                }

                const mapEl = typeof map.getContainer === 'function'
                    ? map.getContainer()
                    : document.getElementById('map');
                const rect = mapEl ? mapEl.getBoundingClientRect() : null;
                if (!rect || rect.width <= 0 || rect.height <= 0) {
                    return null;
                }

                if (typeof map.containerPointToLatLng === 'function'
                    && typeof L !== 'undefined'
                    && typeof L.latLngBounds === 'function') {
                    const northWest = map.containerPointToLatLng([-mapBoundsPaddingPx, -mapBoundsPaddingPx]);
                    const southEast = map.containerPointToLatLng([rect.width + mapBoundsPaddingPx, rect.height + mapBoundsPaddingPx]);
                    const paddedBounds = L.latLngBounds(northWest, southEast);
                    if (paddedBounds && typeof paddedBounds.isValid === 'function' && paddedBounds.isValid()) {
                        return paddedBounds;
                    }
                }

                const bounds = map.getBounds();
                return bounds && typeof bounds.isValid === 'function' && bounds.isValid()
                    ? bounds.pad(0.02)
                    : null;
            }

            function filterMapAndList(query) {
                if (typeof query === 'string') {
                    activeQuery = query.trim().toLowerCase();
                }

                const term = activeQuery;
                const cards = document.querySelectorAll('.cp-card');
                const bounds = getCurrentBounds();
                let visibleCount = 0;

                cards.forEach(card => {
                    const text = (card.dataset.search || '').toLowerCase();
                    const cpId = card.dataset.cpId;
                    const marker = cpId ? markerLookup[cpId] : null;
                    const matchesSearch = term.length === 0 || text.indexOf(term) >= 0;
                    const withinMapBounds = !bounds || (marker && bounds.contains(marker.getLatLng()));
                    const visible = matchesSearch && withinMapBounds;

                    card.style.display = visible ? '' : 'none';

                    if (marker) {
                        if (visible) {
                            if (!map.hasLayer(marker)) {
                                marker.addTo(map);
                            }
                        } else if (map.hasLayer(marker)) {
                            map.removeLayer(marker);
                        }
                    }

                    if (visible) {
                        visibleCount++;
                    }
                });

                if (chargerCountValue) {
                    chargerCountValue.textContent = visibleCount.toString();
                }

                if (emptyStateEl) {
                    emptyStateEl.hidden = visibleCount !== 0;
                }

                if (selectedChargePointId) {
                    const selectedCard = findCardByCpId(selectedChargePointId);
                    if (!selectedCard || selectedCard.style.display === 'none') {
                        clearChargerSelection();
                    }
                }
            }

            function findCardByCpId(cpId) {
                const cards = document.querySelectorAll('.cp-card');
                for (const card of cards) {
                    if (card.dataset && card.dataset.cpId === cpId) {
                        return card;
                    }
                }
                return null;
            }

            function findFirstVisibleCard() {
                const cards = document.querySelectorAll('.cp-card');
                for (const card of cards) {
                    if (card.style.display !== 'none') {
                        return card;
                    }
                }
                return null;
            }

            function findNearestVisibleCard(latlng) {
                if (!latlng || typeof map.distance !== 'function') {
                    return findFirstVisibleCard();
                }

                const cards = document.querySelectorAll('.cp-card');
                let nearestCard = null;
                let nearestDistance = Number.POSITIVE_INFINITY;

                cards.forEach(card => {
                    if (card.style.display === 'none') {
                        return;
                    }

                    const cpId = card.dataset ? card.dataset.cpId : null;
                    const marker = cpId ? markerLookup[cpId] : null;
                    if (!marker) {
                        return;
                    }

                    const distance = map.distance(latlng, marker.getLatLng());
                    if (distance < nearestDistance) {
                        nearestDistance = distance;
                        nearestCard = card;
                    }
                });

                return nearestCard || findFirstVisibleCard();
            }

            function clearChargerSelection() {
                selectedChargePointId = null;
                document.querySelectorAll('.cp-card.active, .cp-card[aria-current="true"]').forEach(activeCard => {
                    activeCard.classList.remove('active');
                    activeCard.removeAttribute('aria-current');
                    activeCard.removeAttribute('data-selection-source');
                });
                updateSelectedMarker(null);
            }

            function selectChargerCard(card, source) {
                if (!card || !card.dataset) {
                    clearChargerSelection();
                    return;
                }

                selectedChargePointId = card.dataset.cpId || null;
                document.querySelectorAll('.cp-card.active, .cp-card[aria-current="true"]').forEach(activeCard => {
                    if (activeCard !== card) {
                        activeCard.classList.remove('active');
                        activeCard.removeAttribute('aria-current');
                        activeCard.removeAttribute('data-selection-source');
                    }
                });

                card.classList.add('active');
                card.setAttribute('aria-current', 'true');
                card.dataset.selectionSource = source || 'list';
                updateSelectedMarker(selectedChargePointId);
            }

            function updateSelectedMarker(cpId) {
                Object.entries(markerLookup).forEach(([markerCpId, marker]) => {
                    if (!marker || typeof marker.setStyle !== 'function') {
                        return;
                    }

                    const baseStyle = marker._publicDefaultStyle || {};
                    if (cpId && markerCpId === cpId) {
                        marker.setStyle({
                            ...baseStyle,
                            radius: 12,
                            color: selectedMarkerColor,
                            fillOpacity: 1,
                            weight: 3
                        });

                        if (typeof marker.bringToFront === 'function') {
                            marker.bringToFront();
                        }
                    } else {
                        marker.setStyle(baseStyle);
                    }
                });
            }

            function scrollToChargerList(card, source) {
                const target = card || findFirstVisibleCard() || listEl || document.querySelector('.map-section-header');
                if (!target) {
                    return;
                }

                target.scrollIntoView({
                    block: card ? 'center' : 'start',
                    behavior: 'smooth'
                });

                if (card) {
                    selectChargerCard(card, source);
                }
            }

            if (searchInput) {
                searchInput.addEventListener('input', function () {
                    filterMapAndList(this.value);
                    if (clearSearch) {
                        clearSearch.style.display = (this.value || '').length > 0 ? 'block' : 'none';
                    }
                });
            }

            if (clearSearch) {
                clearSearch.addEventListener('click', function () {
                    if (searchInput) {
                        searchInput.value = '';
                        filterMapAndList('');
                        searchInput.focus();
                    }
                    clearSearch.style.display = 'none';
                });
            }

            if (listEl) {
                listEl.addEventListener('click', function (ev) {
                    const card = ev.target.closest('.cp-card');
                    if (!card || !card.dataset) return;
                    const cpId = card.dataset.cpId;
                    const marker = markerLookup[cpId];
                    if (!marker) return;
                    const latlng = marker.getLatLng();
                    map.flyTo([latlng.lat, latlng.lng], 16, { animate: true, duration: 0.45 });
                    marker.openTooltip();
                    scrollToChargerList(card, 'list');
                });
            }

            function toggleMapSize() {
                const mapEl = document.getElementById('map');
                if (!mapEl) return;
                const expanded = mapEl.classList.toggle('expanded');
                if (mapExpandBtn) {
                    const labelKey = expanded ? 'map.shrink' : 'map.expand';
                    if (mapExpandLabel) {
                        mapExpandLabel.setAttribute('data-i18n', labelKey);
                        mapExpandLabel.textContent = t(labelKey);
                    } else {
                        mapExpandBtn.textContent = t(labelKey);
                    }
                }
                requestAnimationFrame(() => {
                    map.invalidateSize();
                    filterMapAndList();
                });
            }

            function locateUser(options) {
                const config = options || {};
                if (!navigator.geolocation) return;
                navigator.geolocation.getCurrentPosition(pos => {
                    const lat = pos.coords.latitude;
                    const lng = pos.coords.longitude;
                    if (userMarker) {
                        map.removeLayer(userMarker);
                    }
                    userMarker = L.circleMarker([lat, lng], {
                        radius: 7,
                        color: markerColors.available,
                        fillColor: markerColors.available,
                        fillOpacity: 0.9,
                        weight: 2
                    }).addTo(map);
                    map.flyTo([lat, lng], 15, { animate: true, duration: 0.45 });
                }, err => {
                    if (!config.silent) {
                        console.error('Public map: geolocation failed', err);
                    }
                }, { enableHighAccuracy: true, timeout: 10000 });
            }

            async function autoLocateUser() {
                if (!window.isSecureContext || !navigator.geolocation) {
                    return;
                }

                if (navigator.permissions && typeof navigator.permissions.query === 'function') {
                    try {
                        const permission = await navigator.permissions.query({ name: 'geolocation' });
                        if (permission && permission.state === 'denied') {
                            return;
                        }
                    } catch (_error) {
                        // Ignore unsupported permission queries and fall through to the direct attempt.
                    }
                }

                locateUser({ silent: true });
            }

            if (mapExpandBtn) {
                mapExpandBtn.addEventListener('click', toggleMapSize);
            }

            if (gpsBtn) {
                gpsBtn.addEventListener('click', () => locateUser({ silent: false }));
            }

            const hasFiniteCoordinates = Object.keys(markerLookup).length > 0;
            if (!hasFiniteCoordinates) {
                console.error('Public map: no finite coordinates found in marker list.');
            }

            map.on('moveend', () => filterMapAndList());
            map.on('zoomend', () => filterMapAndList());
            map.on('click', ev => {
                scrollToChargerList(findNearestVisibleCard(ev ? ev.latlng : null), 'map');
            });

            requestAnimationFrame(() => {
                map.invalidateSize();
                if (hasLocation.length > 0) {
                    const bounds = L.latLngBounds(hasLocation.map(p => [asNumber(pick(p, 'Latitude', 'latitude')), asNumber(pick(p, 'Longitude', 'longitude'))]));
                    map.fitBounds(bounds.pad(0.2));
                }

                mapViewportReady = true;
                filterMapAndList(searchInput ? searchInput.value : '');
            });

            filterMapAndList(searchInput ? searchInput.value : '');
            void autoLocateUser();
            window.addEventListener('resize', () => {
                map.invalidateSize();
                requestAnimationFrame(() => filterMapAndList());
            });
            }
        </script>
    }
